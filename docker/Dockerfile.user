# Runnable lerobot image, built on top of the prebuilt dependency base image
# (docker/Dockerfile.deps). The heavy layers — system libraries + the full Python dependency
# set (torch/CUDA, livekit, ...) — live in the base, so source-only changes rebuild in
# seconds instead of minutes.
#
#   docker build -f docker/Dockerfile.user -t lerobot-user .
#   docker run -it --rm lerobot-user
#
# With USB physical access : docker run -it --device=/dev/ -v /dev/:/dev/ --rm lerobot-user

# The dependency base image built from docker/Dockerfile.deps. Its tag is the commit the base
# was built from — it MUST be built from the SAME commit's pyproject.toml + uv.lock as the
# source copied below, otherwise `uv sync --locked` will disagree with the base venv. When
# pyproject.toml / uv.lock change: rebuild Dockerfile.deps and bump this tag. Override at
# build time with --build-arg DEPS_IMAGE=...
ARG DEPS_IMAGE=iaas-us-cn-beijing.cr.volces.com/physicalai/lerobot-livekit-deps:2f797eebe1d6eb14893590448651e5985bbb12fa
FROM ${DEPS_IMAGE}

# The base already provides the venv (/lerobot/.venv), system deps, uv, WORKDIR /lerobot,
# the user_lerobot user and all environment variables — inherited via FROM, no need to repeat.

# Bring in the full application source (git-LFS files included for testing).
COPY --chown=user_lerobot:user_lerobot . .

# Install the lerobot package itself into the prebuilt venv. Every dependency is already
# installed in the base image (Dockerfile.deps ran `uv sync ... --no-install-project`), so
# this only builds/installs lerobot from src/ — seconds, no dependency downloads.
# --inexact: the base image bakes in TransformerEngine (compiled there against a CUDA toolkit that
# is then removed), which is NOT in uv.lock. Without --inexact, `uv sync` prunes anything outside
# the lock and would strip TE (its three dists) back out.
RUN uv sync --locked --extra all --inexact --no-cache

# Set the default command
CMD ["/bin/bash"]
